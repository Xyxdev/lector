# Dependencias (se reinstalan con npm install)
node_modules/
www/lib/jszip.min.js

# Proyecto nativo de Android: se regenera desde cero en cada build de CI
# (ver .github/workflows/build-android.yml), no necesita vivir en el repo.
android/
ios/

# Artefactos de build
*.apk
*.aab
dist/
build/

# Archivos del sistema operativo / editor
.DS_Store
Thumbs.db
*.log

# Variables de entorno / secretos (por si en el futuro se agregan)
.env
.env.local
